{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to MCP server (process id)",
            "type": "debugpy",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "justMyCode": false
        },
        {
            "name": "Run MCP server only (no Inspector)",
            "type": "debugpy",
            "request": "launch",
            "module": "workbench_mcp.server",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "justMyCode": false
        }
    ]
}
