# --- PGSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your-password
DB_SSLMODE=prefer
DB_APPLICATION_NAME=workbench-mcp
DB_QUERY_TIMEOUT_SECONDS=30

# --- HTTP request settings ---
# Default Bearer token used when a tool call does not pass its own `jwt_token`:
API_BEARER_TOKEN=your-jwt-token
# Timezone header added to all HTTP requests:
API_USER_TIMEZONE=America/Chicago
# Maximum time to wait for an HTTP response (seconds):
API_TIMEOUT_SECONDS=30
# Maximum response body size to return (bytes); default is 2 MB:
API_MAX_RESPONSE_BYTES=2097152
# Set to false to skip SSL certificate verification (e.g. local dev with self-signed certs):
# API_VERIFY_SSL=false

