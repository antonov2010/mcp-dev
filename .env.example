# --- PGSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your-password
DB_SSLMODE=prefer
DB_APPLICATION_NAME=workbench-mcp
DB_QUERY_TIMEOUT_SECONDS=30

# --- HTTP request settings ---
# Default Bearer token used when a tool call does not pass its own `jwt_token`:
API_BEARER_TOKEN=your-jwt-token
# Timezone header added to all HTTP requests:
API_USER_TIMEZONE=America/Chicago
# Maximum time to wait for an HTTP response (seconds):
API_TIMEOUT_SECONDS=30
# Maximum response body size to return (bytes); default is 2 MB:
API_MAX_RESPONSE_BYTES=2097152
# Set to false to skip SSL certificate verification (e.g. local dev with self-signed certs):
# API_VERIFY_SSL=false

# --- MCP Session Auth ---
# Backend broker endpoint that exchanges a shared secret + email for a scoped JWT:
MCP_EXCHANGE_URL=https://localhost:5001/api/v1/mcp/exchange
# Shared secret that authenticates this MCP server to the broker (X-MCP-SECRET header):
MCP_SHARED_SECRET=your-mcp-shared-secret
# Refresh the session token when fewer than this many seconds remain (default 60 s):
# MCP_TOKEN_TTL_BUFFER_SECONDS=60

# --- GitHub integration ---
# Base URL for GitHub REST API (defaults to GitHub.com)
GITHUB_API_BASE_URL=https://api.github.com
# Personal access token for GitHub REST API (optional). If set, used when no MCP session token is active.
GITHUB_TOKEN=your-github-token
